# Core
ENV=dev
LOG_LEVEL=INFO
API_BASE_URL=http://localhost:8000
# Comma-separated exact origins. Never use * when credentials are enabled.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
POSTGRES_PASSWORD=change-me
SECRET_KEY=
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
SERVICE_TOKEN=

# Storage
S3_ACCESS_KEY=vcbrain
S3_SECRET_KEY=change-me-too
S3_BUCKET_DECKS=vcbrain-decks
S3_BUCKET_SNAPSHOTS=vcbrain-snapshots
S3_BUCKET_EXPORTS=vcbrain-exports
MAX_UPLOAD_MB=40

# AI providers (all optional; deterministic fallback remains available)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_REASONING=gpt-4.1
OPENAI_MODEL_FAST=gpt-4.1-mini
OPENAI_MODEL_EMBED=text-embedding-3-small
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_REASONING=meta/llama-3.3-70b-instruct
NVIDIA_MODEL_EMBED=nvidia/nv-embedqa-e5-v5
LLM_DAILY_USD_BUDGET=40
LLM_PER_OPPORTUNITY_USD_CAP=1.50
LLM_REQUEST_TIMEOUT_S=60

# Search/connectors
TAVILY_API_KEY=
GITHUB_TOKEN=
CONTACT_EMAIL=team@example.com
USER_AGENT=VCBrain/0.1 (+https://example.com; team@example.com)

# Behaviour
CONVICTION_THRESHOLD=72
DECISION_SLA_HOURS=24
ENABLE_WEB_FALLBACK=true
ALLOW_SCRAPE_DOMAINS=devpost.com,news.ycombinator.com
DEMO_MODE=false
AUTO_CREATE_SCHEMA=false
QUEUE_EAGER=false

# Optional observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
GIT_SHA=dev
BUILT_AT=unknown

# Optional n8n profile
N8N_USER=operator
N8N_PASSWORD=change-me
VCBRAIN_ORG_ID=
